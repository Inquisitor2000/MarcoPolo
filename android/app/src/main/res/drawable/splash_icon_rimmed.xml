<!--
    Used as windowSplashScreenAnimatedIcon on Android 12+.
    System displays it at ~96dp — oval + inset icon produce a green ring effect.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Green rim: oval with transparent fill -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent"/>
            <stroke
                android:width="6dp"
                android:color="#FF4ADE80"/>
        </shape>
    </item>

    <!-- Icon, inset so the rim peeks around the edge -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <bitmap
            android:src="@drawable/splash_icon"
            android:gravity="center"/>
    </item>
</layer-list>
